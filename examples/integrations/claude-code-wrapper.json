{
  "actor": "claude-code",
  "agent": "claude-code",
  "auditStore": ".agentfence/audit.sqlite",
  "command": [
    "agentfence",
    "run",
    "--actor",
    "claude-code",
    "--",
    "claude"
  ],
  "init": {
    "command": [
      "agentfence",
      "init",
      "--preset",
      "developer",
      "--project",
      "claude-code-project"
    ]
  },
  "notes": [
    "Replace the final command with the installed Claude Code binary if needed.",
    "Use daemon approvals when the desktop app is running."
  ],
  "policy": "examples/claude-code.policy.json",
  "profile": "claude-code",
  "recommendedPreset": "developer"
}
